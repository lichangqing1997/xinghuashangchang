<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="false"
      internalLogLevel="Off"
      internalLogFile="internal-nlog.txt">

  <variable name="logDirectory" value="${basedir}/logs" />

  <targets>
    <!-- 调试日志 - 按级别分文件 -->
    <target name="debugFile" xsi:type="File"
            fileName="${logDirectory}/debug/${shortdate}.log"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message}${onexception:inner= ${exception:format=tostring}}" />

    <!-- 错误日志单独文件 -->
    <target name="errorFile" xsi:type="File"
            fileName="${logDirectory}/error/${shortdate}.log"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message}${onexception:inner= ${exception:format=tostring}}" />

    <!-- 控制台输出 -->
    <target name="console" xsi:type="Console"
            layout="${longdate}|${level:uppercase=true}|${logger}|${message}${onexception:inner= ${exception:format=tostring}}" />
  </targets>

  <rules>
    <!-- 调试日志：Debug及以上级别 -->
    <logger name="*" minlevel="Debug" writeTo="debugFile" final="true" />

    <!-- 错误日志：Error及以上级别 -->
    <logger name="*" minlevel="Error" writeTo="errorFile" final="true" />

    <!-- 开发环境控制台输出 -->
    <logger name="*" minlevel="Debug" writeTo="console" final="true" />
  </rules>
</nlog>
